[submodule "custom/plugins/zsh-nvm"]
	path = custom/plugins/zsh-nvm
	url = https://github.com/lukechilds/zsh-nvm
[submodule "custom/plugins/zsh-syntax-highlighting"]
	path = custom/plugins/zsh-syntax-highlighting
	url = git://github.com/zsh-users/zsh-syntax-highlighting.git
[submodule "custom/plugins/zsh-git-prompt"]
	path = custom/plugins/zsh-git-prompt
	url = https://github.com/cristianstu/zsh-git-prompt.git
[submodule "custom/plugins/zsh-completions"]
	path = custom/plugins/zsh-completions
	url = https://github.com/zsh-users/zsh-completions.git
